{
    "name": "gonon/http-symfony",
    "description": "Symfony HTTP Client adapter for the Gonon ecosystem",
    "keywords": [
        "gonon",
        "symfony",
        "http-client",
        "adapter",
        "api"
    ],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Gonon",
            "email": "nurfaizfy19@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "gonon/core": "^1.0",
        "symfony/http-client": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.10",
        "laravel/pint": "^1.13"
    },
    "autoload": {
        "psr-4": {
            "Gonon\\Http\\Symfony\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Gonon\\Http\\Symfony\\Tests\\": "tests/"
        }
    },
    "homepage": "https://github.com/GononLabs/http-symfony",
    "support": {
        "issues": "https://github.com/GononLabs/http-symfony/issues",
        "source": "https://github.com/GononLabs/http-symfony"
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "format": "vendor/bin/pint",
        "analyse": "vendor/bin/phpstan analyse"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}